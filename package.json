{
  "name": "revolute-business-api",
  "version": "0.1.0",
  "private": true,
  "description": "Bank-to-bank payment orchestration scaffold for the Revolut Business API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@fastify/sensible": "^6.0.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jose": "^6.0.8",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "eslint": "^9.20.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.6"
  }
}
