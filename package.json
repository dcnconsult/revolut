{
  "name": "revolute-business-api",
  "version": "0.3.0",
  "private": true,
  "description": "Bank-to-bank payment orchestration with manual and ISO 20022 XML ingestion for the Revolut Business API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm test",
    "test:iso20022": "vitest run tests/iso20022-parser.test.ts tests/iso20022-routes.test.ts",
    "sandbox:setup": "node scripts/sandbox/setup.mjs",
    "sandbox:accounts": "node scripts/sandbox/accounts.mjs",
    "sandbox:topup": "node scripts/sandbox/topup.mjs",
    "sandbox:simulate": "node scripts/sandbox/simulate-transfer.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/multipart": "^10.1.0",
    "@fastify/sensible": "^6.0.2",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^5.10.1",
    "fastify": "^5.2.1",
    "jose": "^6.0.8",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "eslint": "^9.20.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.6"
  },
  "packageManager": "npm@10.9.2"
}
