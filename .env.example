NODE_ENV=development
PORT=3000
LOG_LEVEL=info
REVOLUT_MODE=mock
REVOLUT_BASE_URL=https://sandbox-b2b.revolut.com/api/1.0
REVOLUT_CLIENT_ID=
REVOLUT_ISSUER=https://your-domain.example
REVOLUT_PRIVATE_KEY_PATH=/run/secrets/revolut-private.pem
REVOLUT_REFRESH_TOKEN=
REVOLUT_WEBHOOK_SIGNING_SECRET=
PAYMENT_MAX_AMOUNT_MINOR=100000000
PAYMENT_ALLOWED_CURRENCIES=EUR,GBP,CHF,USD
PAYMENT_REQUIRE_NAME_MATCH=true
